# relay-master configuration

# HTTP listener (Web UI + REST API)
MASTER_HTTP_ADDR=0.0.0.0:7080

# gRPC listener (node control plane, mTLS in M4)
MASTER_GRPC_ADDR=0.0.0.0:7443

# Enrollment listener (TLS, no client cert; nodes call Enroll here on first
# install to exchange their enrollment_token for a signed client cert).
MASTER_ENROLL_ADDR=0.0.0.0:7444

# Public address(es) clients connect to (DNS names and/or IPs, comma-separated).
# Used as the SAN of the master TLS server cert. REQUIRED — master refuses to
# start if unset. Changing this triggers an automatic resign on next restart.
# MASTER_PUBLIC_ADDR=master.example.com,10.0.0.1

# PKI directory (CA + server cert + private keys live here, mode 0600).
# Default: /var/lib/relay-master/pki (provisioned by systemd StateDirectory=).
# MASTER_PKI_DIR=/var/lib/relay-master/pki

# PostgreSQL connection. Provision the database yourself before starting.
#   sudo -u postgres psql -c "CREATE USER relay WITH PASSWORD 'CHANGE_ME';"
#   sudo -u postgres psql -c "CREATE DATABASE relay OWNER relay;"
MASTER_DATABASE_URL=postgres://relay:CHANGE_ME@127.0.0.1:5432/relay

# Used to sign admin / node JWTs. Generate with: openssl rand -hex 32
MASTER_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Optional log filter
RUST_LOG=info,relay_master=info
