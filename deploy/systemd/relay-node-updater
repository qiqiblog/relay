#!/usr/bin/env bash
# relay-node-updater — runs as root, triggered by systemd path unit on
# /var/lib/relay-node/upgrade-request.json. Downloads the requested release,
# verifies SHA256, atomically swaps the symlink, restarts the service, and
# rolls back on failure.
#
# This script is intentionally self-contained (no external deps beyond
# curl, tar, sha256sum, systemctl, jq) and treats every input as untrusted.

set -euo pipefail

REQ=/var/lib/relay-node/upgrade-request.json
STATUS=/var/lib/relay-node/upgrade-status.json
LIB_DIR=/usr/local/lib/relay-node
BIN_LINK=/usr/local/bin/relay-node
UNIT=relay-node

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }

write_status() {
  local job="$1" state="$2" err="${3:-}"
  cat > "$STATUS.tmp" <<JSON
{"job_id": $job, "state": "$state", "error": $(printf '%s' "$err" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'), "completed_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
JSON
  mv -f "$STATUS.tmp" "$STATUS"
}

[[ -f "$REQ" ]] || { warn "no $REQ; nothing to do"; exit 0; }
command -v jq        >/dev/null || { warn "jq required"; exit 2; }
command -v curl      >/dev/null || { warn "curl required"; exit 2; }
command -v sha256sum >/dev/null || { warn "sha256sum required"; exit 2; }
command -v systemctl >/dev/null || { warn "systemctl required"; exit 2; }

JOB=$(jq -r '.job_id // empty' "$REQ")
TAG=$(jq -r '.tag // empty' "$REQ")
ASSET_URL_AMD64=$(jq -r '.asset_url_amd64 // empty' "$REQ")
ASSET_URL_ARM64=$(jq -r '.asset_url_arm64 // empty' "$REQ")
SUMS_URL=$(jq -r '.sha256_url // empty' "$REQ")

[[ -n "$JOB" && -n "$TAG" && -n "$ASSET_URL_AMD64" && -n "$ASSET_URL_ARM64" && -n "$SUMS_URL" ]] \
  || { warn "request.json missing fields"; rm -f "$REQ"; exit 2; }

# Defense-in-depth: re-validate tag form here even though master also did.
if ! [[ "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+(-rc\.[0-9A-Za-z.]+)?$ ]]; then
  warn "rejecting malformed tag: $TAG"
  write_status "$JOB" "failed" "malformed tag"
  rm -f "$REQ"
  exit 2
fi

# Only allow github.com / objects.githubusercontent.com hosts.
for url in "$ASSET_URL_AMD64" "$ASSET_URL_ARM64" "$SUMS_URL"; do
  case "$url" in
    https://github.com/*|https://objects.githubusercontent.com/*) ;;
    *) warn "rejecting URL host: $url"
       write_status "$JOB" "failed" "url host not allowed"
       rm -f "$REQ"; exit 2 ;;
  esac
done

OS=$(uname -s); ARCH=$(uname -m)
case "$OS-$ARCH" in
  Linux-x86_64)              TARGET="x86_64-unknown-linux-gnu"; ASSET_URL="$ASSET_URL_AMD64" ;;
  Linux-aarch64|Linux-arm64) TARGET="aarch64-unknown-linux-gnu"; ASSET_URL="$ASSET_URL_ARM64" ;;
  *) warn "unsupported platform $OS $ARCH"
     write_status "$JOB" "failed" "unsupported platform"
     rm -f "$REQ"; exit 2 ;;
esac

ASSET_BASENAME="relay-${TAG}-${TARGET}.tar.gz"
case "$ASSET_URL" in
  *"/$ASSET_BASENAME") ;;
  *) warn "asset_url does not match expected basename $ASSET_BASENAME"
     write_status "$JOB" "failed" "asset url basename mismatch"
     rm -f "$REQ"; exit 2 ;;
esac

STAGE=$(mktemp -d)
trap 'rm -rf "$STAGE"' EXIT

log "downloading $ASSET_URL"
curl -fsSL --max-time 300 "$ASSET_URL" -o "$STAGE/pkg.tar.gz" \
  || { write_status "$JOB" "failed" "asset download failed"; rm -f "$REQ"; exit 1; }

log "downloading $SUMS_URL"
curl -fsSL --max-time 60  "$SUMS_URL"  -o "$STAGE/SHA256SUMS" \
  || { write_status "$JOB" "failed" "sha256sums download failed"; rm -f "$REQ"; exit 1; }

log "verifying sha256"
( cd "$STAGE" && grep " $ASSET_BASENAME\$" SHA256SUMS > expected.sums \
  && [[ -s expected.sums ]] \
  && cp pkg.tar.gz "$ASSET_BASENAME" \
  && sha256sum -c expected.sums ) \
  || { write_status "$JOB" "failed" "checksum mismatch"; rm -f "$REQ"; exit 1; }

DEST="$LIB_DIR/relay-node-$TAG"
mkdir -p "$DEST"
tar -xzf "$STAGE/pkg.tar.gz" -C "$STAGE/extract" --one-top-level=extract \
  || { mkdir -p "$STAGE/extract" && tar -xzf "$STAGE/pkg.tar.gz" -C "$STAGE/extract"; }

# Find the binary inside the archive — it may be at top-level or under a
# release directory like relay-vX.Y.Z-TARGET/.
NEW_BIN=$(find "$STAGE/extract" -maxdepth 3 -type f -name relay-node -perm -u+x | head -1)
[[ -n "$NEW_BIN" ]] || { write_status "$JOB" "failed" "relay-node not in archive"; rm -f "$REQ"; exit 1; }

install -m 0755 "$NEW_BIN" "$DEST/relay-node"

# Capture previous binary/symlink for rollback. We support both the
# legacy plain-binary install (BIN_LINK is a regular file) and the
# new symlinked install.
PREV_KIND="" # "symlink" | "file" | "absent"
PREV_TARGET=""   # for symlink: real path; for file: backup path
if [[ -L "$BIN_LINK" ]]; then
  PREV_KIND="symlink"
  PREV_TARGET=$(readlink -f "$BIN_LINK" || true)
elif [[ -f "$BIN_LINK" ]]; then
  PREV_KIND="file"
  PREV_TARGET="${BIN_LINK}.bak"
  cp -f "$BIN_LINK" "$PREV_TARGET" \
    || { write_status "$JOB" "failed" "could not back up legacy binary"; rm -f "$REQ"; exit 1; }
else
  PREV_KIND="absent"
fi

rollback() {
  warn "rollback: restoring previous $PREV_KIND install"
  case "$PREV_KIND" in
    symlink)
      if [[ -n "$PREV_TARGET" && -x "$PREV_TARGET" ]]; then
        ln -sfn "$PREV_TARGET" "${BIN_LINK}.new" \
          && mv -Tf "${BIN_LINK}.new" "$BIN_LINK"
      fi
      ;;
    file)
      if [[ -f "$PREV_TARGET" ]]; then
        cp -f "$PREV_TARGET" "${BIN_LINK}.new" \
          && mv -Tf "${BIN_LINK}.new" "$BIN_LINK"
      fi
      ;;
  esac
  systemctl restart "$UNIT" || true
}

log "stopping $UNIT"
systemctl stop "$UNIT" || true

# Atomic symlink swap via temp + mv -T (mv -Tf is atomic when both paths
# are on the same filesystem). `ln -sfn` directly is *not* atomic — it
# unlinks and recreates with a window.
ln -sfn "$DEST/relay-node" "${BIN_LINK}.new"
if ! mv -Tf "${BIN_LINK}.new" "$BIN_LINK"; then
  warn "atomic symlink swap failed"
  rm -f "${BIN_LINK}.new"
  rollback
  write_status "$JOB" "failed" "symlink swap failed"
  rm -f "$REQ"
  exit 1
fi

log "starting $UNIT"
if ! systemctl start "$UNIT"; then
  warn "service failed to start; rolling back"
  rollback
  write_status "$JOB" "failed" "service failed to start"
  rm -f "$REQ"
  exit 1
fi

# Brief wait + active check.
sleep 5
if ! systemctl is-active --quiet "$UNIT"; then
  warn "service not active after 5s; rolling back"
  rollback
  write_status "$JOB" "failed" "service inactive after restart"
  rm -f "$REQ"
  exit 1
fi

# Success: drop the legacy backup if we made one.
if [[ "$PREV_KIND" == "file" && -f "$PREV_TARGET" ]]; then
  rm -f "$PREV_TARGET"
fi

log "installed $TAG; previous install kind: $PREV_KIND"
write_status "$JOB" "installed" ""
rm -f "$REQ"
