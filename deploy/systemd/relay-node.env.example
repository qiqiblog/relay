# relay-node environment.
# Edit and then: systemctl restart relay-node

# Master gRPC endpoint (mTLS, https:// scheme is required so tonic uses TLS).
NODE_MASTER_ENDPOINT=https://master.example.com:7443

# Unique node id (must match the cert SAN issued by the master).
NODE_ID=node-1

# Where to store the issued client cert + CA. Default matches the systemd
# StateDirectory= (provisioned 0700, owned by relay:relay).
NODE_PKI_DIR=/var/lib/relay-node/pki

# Optional: override the TLS server name used to verify the master cert.
# Defaults to the host part of NODE_MASTER_ENDPOINT.
# NODE_MASTER_SERVER_NAME=master.example.com

# --- M4.4 (cold start enrollment, populated by install-node.sh) ---
# These are only consumed on first launch (when NODE_PKI_DIR is empty).
# Once a cert is on disk they are ignored and may be removed.

# Master enrollment endpoint (TLS, no client cert required).
# NODE_MASTER_ENROLL_ENDPOINT=https://master.example.com:7444

# One-time enrollment token (rotated by master after use).
# NODE_TOKEN=changeme

# Base64-encoded CA cert pinned at install time so we can verify the
# enrollment endpoint without TOFU.
# NODE_CA_CERT_B64=
